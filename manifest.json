{
  "manifest_version": 2,
  "name": "Click Assistant",
  "version": "2.0",
  "description": "Automatically clicks buttons (e.g., login, submit).",
  "permissions": [
    "storage",
    "activeTab",
    "scripting"
  ],
  "browser_specific_settings": {
    "gecko": {
      "id": "click-assistant@demo.invalid",
      "data_collection_permissions": {
        "required": ["none"]
      }
    }
  },
  "background": {
    "scripts": ["background.js"]
  },
  "browser_action": {
    "default_popup": "popup.html",
    "default_title": "Click Assistant Settings"
  },
  "icons": {
    "2048": "pic.png"
  },
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["content.js"],
      "run_at": "document_end"
    }
  ]
}